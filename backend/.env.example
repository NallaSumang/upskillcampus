# Smart Factory Dashboard — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME="Smart Factory Dashboard API"
APP_VERSION="2.0.0"
DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000

# Database (SQLite default — swap to PostgreSQL for production)
DATABASE_URL=sqlite:///./factory.db

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000"]
